{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://clawtfup.local/schemas/evaluation_report.json",
  "title": "Policy evaluation report envelope",
  "type": "object",
  "required": [
    "schema_version",
    "evaluation_id",
    "timestamp",
    "duration_ms",
    "inputs",
    "results",
    "engine"
  ],
  "properties": {
    "schema_version": { "type": "integer" },
    "evaluation_id": { "type": "string", "format": "uuid" },
    "timestamp": { "type": "string", "description": "RFC 3339 UTC" },
    "duration_ms": { "type": "integer", "minimum": 0 },
    "inputs": {
      "type": "object",
      "additionalProperties": true
    },
    "results": {
      "type": "object",
      "description": "OPA query string to JSON value (opaque per query)",
      "additionalProperties": true
    },
    "findings": {
      "type": "array",
      "items": { "type": "object", "additionalProperties": true }
    },
    "allow": { "type": "boolean" },
    "summary": { "type": "object", "additionalProperties": true },
    "query_errors": {
      "type": "array",
      "items": { "type": "object", "additionalProperties": true }
    },
    "engine": {
      "type": "object",
      "required": ["queries"],
      "properties": {
        "opa_version": { "type": ["string", "null"] },
        "queries": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
